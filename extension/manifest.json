{
  "manifest_version": 3,
  "name": "KeyMonitor - Parental Control",
  "version": "1.0",
  "description": "Silent parental keyboard monitoring. Records keystrokes from all browser tabs.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "KeyMonitor"
  }
}
